# Development Dockerfile with hot-reload
FROM golang:1.23-alpine

WORKDIR /app

# Install build tools
RUN apk add --no-cache git build-base

# Install air (correct module path, pinned to a valid release)
RUN go install github.com/air-verse/air@v1.52.3

# Copy go mod files
COPY go.mod go.sum ./
RUN go mod download

# Copy source
COPY . .

EXPOSE 8080
CMD ["air", "-c", ".air.toml"]